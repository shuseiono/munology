---
export interface Props {
  variant?: 'primary' | 'secondary' | 'danger';
  size?: 'small' | 'medium' | 'large';
  disabled?: boolean;
  type?: 'button' | 'submit' | 'reset';
  href?: string;
  class?: string;
  ariaLabel?: string;
  ariaDescribedBy?: string;
}

const {
  variant = 'primary',
  size = 'medium',
  disabled = false,
  type = 'button',
  href,
  class: className = '',
  ariaLabel,
  ariaDescribedBy,
} = Astro.props;

const baseClasses =
  'inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-mun-focus focus-visible:ring-offset-2 focus-visible:ring-offset-mun-bg disabled:opacity-50 disabled:cursor-not-allowed';

const variantClasses = {
  primary:
    'bg-mun-accent hover:opacity-90 text-mun-bg font-semibold shadow-lg hover:shadow-xl',
  secondary:
    'bg-transparent border-2 border-mun-border text-mun-text-secondary hover:border-mun-accent hover:text-mun-text',
  danger: 'bg-red-600 hover:bg-red-700 text-white focus-visible:ring-red-500',
};

const sizeClasses = {
  small: 'px-3 py-1.5 text-sm',
  medium: 'px-4 py-2 text-base',
  large: 'px-6 py-3 text-lg',
};

const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className}`;
---

{href ? (
  <a
    href={href}
    class={classes}
    role="button"
    tabindex={disabled ? -1 : 0}
    aria-label={ariaLabel}
    aria-describedby={ariaDescribedBy}
    aria-disabled={disabled ? 'true' : undefined}
  >
    <slot />
  </a>
) : (
  <button
    type={type}
    disabled={disabled}
    class={classes}
    aria-label={ariaLabel}
    aria-describedby={ariaDescribedBy}
  >
    <slot />
  </button>
)}
