---
export interface Props {
  variant?: 'default' | 'success' | 'warning' | 'danger' | 'info';
  size?: 'small' | 'medium';
  class?: string;
}

const { variant = 'default', size = 'medium', class: className = '' } = Astro.props;

const baseClasses = 'inline-flex items-center font-medium rounded-full';

const variantClasses: Record<string, string> = {
  default: 'bg-mun-elevated text-mun-text-secondary border border-mun-border',
  success: 'text-emerald-300 bg-emerald-500/15 border border-emerald-500/25',
  warning: 'text-amber-300 bg-amber-500/15 border border-amber-500/25',
  danger: 'text-red-300 bg-red-500/15 border border-red-500/25',
  info: 'text-sky-300 bg-sky-500/15 border border-sky-500/25',
};

const sizeClasses = {
  small: 'px-2 py-0.5 text-xs',
  medium: 'px-3 py-1 text-sm',
};

const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className}`;
---

<span class={classes}>
  <slot />
</span>
