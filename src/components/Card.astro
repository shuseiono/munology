---
export interface Props {
  href?: string;
  class?: string;
  ariaLabel?: string;
  ariaDescribedBy?: string;
  variant?: 'info' | 'success' | 'warning' | 'default';
}

const { href, class: className = '', ariaLabel, ariaDescribedBy, variant = 'default' } = Astro.props;

const baseClasses =
  'card-bg rounded-lg overflow-hidden transition-colors duration-200 shadow-sm border border-mun-border';
const variantHover: Record<string, string> = {
  info: 'hover:border-sky-400/50',
  success: 'hover:border-emerald-400/50',
  warning: 'hover:border-amber-400/50',
  default: 'hover:border-mun-border',
};
const classes = `${baseClasses} ${variantHover[variant]} ${className}`;
---

{href ? (
  <a
    href={href}
    class={`${classes} block hover:border-mun-text-muted/25`}
    aria-label={ariaLabel}
    aria-describedby={ariaDescribedBy}
  >
    <div class="p-6">
      <slot />
    </div>
  </a>
) : (
  <div class={classes} role="article" aria-label={ariaLabel} aria-describedby={ariaDescribedBy}>
    <div class="p-6">
      <slot />
    </div>
  </div>
)}
