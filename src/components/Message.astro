---
export interface Props {
  type?: 'info' | 'success' | 'warning' | 'error';
  title?: string;
  class?: string;
}

const { type = 'info', title, class: className = '' } = Astro.props;

const baseClasses = 'p-4 rounded-lg border text-sm font-noto leading-relaxed';

const typeClasses: Record<string, string> = {
  info: 'bg-sky-500/10 border-sky-500/25 text-sky-100/95',
  success: 'bg-emerald-500/10 border-emerald-500/25 text-emerald-100/95',
  warning: 'bg-amber-500/10 border-amber-500/25 text-amber-100/95',
  error: 'bg-red-500/10 border-red-500/25 text-red-100/95',
};

const classes = `${baseClasses} ${typeClasses[type]} ${className}`;
---

<div class={classes}>
  {title && <p class="font-medium mb-1">{title}</p>}
  <div>
    <slot />
  </div>
</div>
