---
export interface Props {
  title: string;
  description?: string;
  breadcrumbs?: Array<{ label: string; href?: string }>;
  actions?: any;
}

const { title, description, breadcrumbs, actions } = Astro.props;
---

<header class="page-header bg-mun-surface/90 border-b border-mun-border">
  <div class="layout-shell py-8 md:py-10">
    {breadcrumbs && breadcrumbs.length > 0 && (
      <nav class="mb-4" aria-label="パンくずリスト">
        <ol class="flex items-center space-x-2 text-sm text-mun-text-muted">
          {breadcrumbs.map((item, index) => (
            <li class="flex items-center">
              {index > 0 && (
                <svg class="w-4 h-4 mx-2 text-mun-text-muted" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                    clip-rule="evenodd"
                  />
                </svg>
              )}
              {item.href ? (
                <a href={item.href} class="hover:text-mun-accent transition-colors">
                  {item.label}
                </a>
              ) : (
                <span class="text-mun-text-secondary">{item.label}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>
    )}

    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 md:gap-8">
      <div class="min-w-0 max-w-3xl">
        <h1 class="text-3xl sm:text-4xl font-bold text-mun-text mb-2 font-noto">
          {title}
        </h1>
        {description && (
          <p class="text-mun-text-secondary text-base sm:text-lg font-noto leading-relaxed">{description}</p>
        )}
      </div>

      {actions && (
        <div class="flex flex-wrap gap-3">
          <slot name="actions" />
        </div>
      )}
    </div>
  </div>
</header>
