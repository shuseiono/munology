---
// src/components/ArticleCard.astro
// カテゴリ色は完全なクラス文字列で指定（Tailwind JIT 対応 — Design.md / AGENTS.md）
export interface Props {
  title: string;
  description: string;
  category: string;
  date: Date;
  tags: string[];
  slug: string;
  image?: string;
}

const { title, description, category, date, tags, slug, image } = Astro.props;

const CATEGORY_STYLES: Record<
  string,
  {
    borderHover: string;
    badge: string;
    titleLink: string;
    cta: string;
  }
> = {
  最新動向: {
    borderHover: 'hover:border-sky-400/40',
    badge: 'text-sky-300 bg-sky-500/15 group-hover:bg-sky-500/25',
    titleLink: 'text-mun-text hover:text-sky-300',
    cta: 'text-sky-400 hover:text-sky-300',
  },
  頻出トピック: {
    borderHover: 'hover:border-emerald-400/40',
    badge: 'text-emerald-300 bg-emerald-500/15 group-hover:bg-emerald-500/25',
    titleLink: 'text-mun-text hover:text-emerald-300',
    cta: 'text-emerald-400 hover:text-emerald-300',
  },
  コア文書: {
    borderHover: 'hover:border-amber-400/40',
    badge: 'text-amber-300 bg-amber-500/15 group-hover:bg-amber-500/25',
    titleLink: 'text-mun-text hover:text-amber-300',
    cta: 'text-amber-400 hover:text-amber-300',
  },
  学問的探究: {
    borderHover: 'hover:border-violet-400/40',
    badge: 'text-violet-300 bg-violet-500/15 group-hover:bg-violet-500/25',
    titleLink: 'text-mun-text hover:text-violet-300',
    cta: 'text-violet-400 hover:text-violet-300',
  },
  default: {
    borderHover: 'hover:border-mun-border',
    badge: 'text-mun-text-secondary bg-mun-elevated/60 group-hover:bg-mun-elevated',
    titleLink: 'text-mun-text hover:text-mun-accent',
    cta: 'text-mun-accent hover:text-mun-link',
  },
};

const styles = CATEGORY_STYLES[category] ?? CATEGORY_STYLES.default;
---

<article
  class={`group card-bg rounded-lg overflow-hidden transition-colors duration-200 shadow-sm border border-mun-border ${styles.borderHover}`}
>
  {image && (
    <div class="relative h-48 overflow-hidden">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
    </div>
  )}

  <div class="p-6">
    <div class="flex items-center justify-between mb-3">
      <span
        class={`text-sm font-bold px-3 py-1 rounded-full transition-all duration-300 ${styles.badge}`}
      >
        {category}
      </span>
      <span class="text-xs text-mun-text-muted">
        {new Date(date).toLocaleDateString('ja-JP')}
      </span>
    </div>

    <h2 class="font-bold text-xl mb-3 h-16 font-noto line-clamp-2">
      <a href={`/articles/${slug}`} class={`transition-colors ${styles.titleLink}`}>
        {title}
      </a>
    </h2>

    <p class="text-mun-text-muted text-sm h-20 overflow-hidden mb-4">
      {description}
    </p>

    {tags.length > 0 && (
      <p class="text-xs text-mun-text-muted mb-4 leading-relaxed line-clamp-2">
        {tags.slice(0, 4).join('、')}
      </p>
    )}

    <a
      href={`/articles/${slug}`}
      class={`text-sm font-medium border-b border-transparent group-hover:border-current pb-0.5 transition-colors ${styles.cta}`}
    >
      続きを読む
    </a>
  </div>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
