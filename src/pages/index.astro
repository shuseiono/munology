---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import Badge from '../components/Badge.astro';
import Button from '../components/Button.astro';
import Grid from '../components/Grid.astro';
import Stack from '../components/Stack.astro';

const pageTitle = "MUNOLOGY | 国際法と模擬国連の探究";
const pageDescription =
  "会期の向こう側で、条約・判例・概念を法と政治の枠で読み解く。高校以上向けの編集型読み物（Beyond the Gavel）。";
---

<BaseLayout pageTitle={pageTitle} pageDescription={pageDescription}>
  <div class="page-main">
    <!-- ヒーロー: hero-index.png + 暗幕。画像差し替えは public/images/hero-index.png -->
    <section
      class="index-hero relative flex min-h-[min(85vh,52rem)] items-center px-6 py-20 md:py-28"
    >
      <div class="absolute inset-0 bg-mun-bg/80" aria-hidden="true"></div>
      <div class="relative z-10 container mx-auto max-w-3xl">
        <h1 class="page-display-title text-4xl md:text-5xl lg:text-6xl">
          <span class="block text-xs text-mun-text-muted font-normal tracking-wide font-sans" lang="en"
            >Beyond the Gavel</span
          >
          <span class="block mt-2">DRの向こう側へ</span>
        </h1>
        <p class="page-lead mt-6">
          模擬国連の会期が終わったあとでも続く、地続きの学びのために。MUNOLOGYは、国際法・国際政治のトピックを<strong class="text-mun-text font-semibold">根拠と論点が追える</strong>文章で届ける編集型サイトです。高校以上の探究者向けに、法学・政治学の枠組みを示しながら積み上げます。
        </p>
        <div class="mt-10 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <Button href="/articles" variant="primary" size="large" ariaLabel="記事一覧へ">
            記事を読む
          </Button>
          <Button href="/about" variant="secondary" size="large" ariaLabel="MUNOLOGYについて">
            このサイトについて
          </Button>
        </div>
      </div>
    </section>

    <!-- おすすめ記事 -->
    <section id="articles" class="border-t border-mun-border py-16 md:py-20">
      <div class="container mx-auto px-6">
        <div class="mb-12 max-w-3xl">
          <h2 class="section-heading text-2xl md:text-3xl">おすすめ記事</h2>
          <p class="section-lead">会議用の要約の先、条文・学説・動向を読み解く記事の一部です。</p>
        </div>

        <Grid cols={3} gap="large">
          <Card href="/articles/icj-climate-change" ariaLabel="気候変動に関するICJ勧告的意見" variant="info">
            <div class="flex items-center justify-between gap-4 mb-4">
              <Badge variant="info">最新動向</Badge>
              <time class="text-xs text-mun-text-muted whitespace-nowrap" datetime="2024-07-25">2024.07.25</time>
            </div>
            <h3 class="font-semibold text-lg mb-3 min-h-[3.5rem] font-noto text-mun-text group-hover:text-sky-300 transition-colors">
              速報解説：気候変動に関するICJ勧告的意見
            </h3>
            <p class="text-mun-text-muted text-sm mb-6 leading-relaxed line-clamp-4">
              UNFCCCやパリ協定の法的拘束力、Lex Specialisといった法理を解説し、国際法における気候変動問題の新たな展開を分析します。
            </p>
            <span class="text-sm font-medium text-sky-400 group-hover:text-sky-300 border-b border-transparent group-hover:border-sky-400/50 transition-colors">
              続きを読む
            </span>
          </Card>

          <Card href="/articles/non-intervention-principle" ariaLabel="内政不干渉の原則" variant="success">
            <div class="flex items-center justify-between gap-4 mb-4">
              <Badge variant="success">頻出トピック</Badge>
              <time class="text-xs text-mun-text-muted whitespace-nowrap" datetime="2024-07-24">2024.07.24</time>
            </div>
            <h3 class="font-semibold text-lg mb-3 min-h-[3.5rem] font-noto text-mun-text group-hover:text-emerald-300 transition-colors">
              徹底解説：内政（不）干渉の原則
            </h3>
            <p class="text-mun-text-muted text-sm mb-6 leading-relaxed line-clamp-4">
              WW2以前から現代のR2P、国際刑事法に至る歴史的変遷を概観。会議で直面するケーススタディを豊富に盛り込みます。
            </p>
            <span class="text-sm font-medium text-emerald-400 group-hover:text-emerald-300 border-b border-transparent group-hover:border-emerald-400/50 transition-colors">
              続きを読む
            </span>
          </Card>

          <Card href="#" ariaLabel="国連憲章から読み解く内政不干渉（準備中）" variant="warning">
            <div class="flex items-center justify-between gap-4 mb-4">
              <Badge variant="warning">コア文書</Badge>
              <span class="text-xs text-mun-text-muted">準備中</span>
            </div>
            <h3 class="font-semibold text-lg mb-3 min-h-[3.5rem] font-noto text-mun-text group-hover:text-amber-300 transition-colors">
              国連憲章から読み解く「内政不干渉」
            </h3>
            <p class="text-mun-text-muted text-sm mb-6 leading-relaxed line-clamp-4">
              なぜ2条7項が置かれたのか。安保理の権限（第7章）との関係性を明確にし、歴史的・構造的理解を深めます。
            </p>
            <span class="text-sm font-medium text-amber-400/80">公開までお待ちください</span>
          </Card>
        </Grid>
      </div>
    </section>

    <!-- サイトについて -->
    <section id="about" class="border-t border-mun-border py-16 md:py-20">
      <div class="container mx-auto px-6">
        <div class="max-w-3xl">
          <h2 class="section-heading text-2xl md:text-3xl">MUNOLOGYについて</h2>
          <div class="section-lead mt-6 space-y-6 text-mun-text-secondary">
            <p>
              議場の熱量そのものではなく、<strong class="text-mun-text font-semibold">会期のあと</strong>に残る教養と探究に寄与したいと考えています。図書室や良い新聞の解説欄のように、装飾より<strong class="text-mun-text font-semibold">可読性と階層</strong>を優先し、国際社会で責任を持つ次の世代の土台づくりに、テキストの面から補助したい、という願いです。
            </p>
            <p class="text-mun-text-muted text-base">
              教育資源へのアクセスに差がある現実を踏まえ、可能な形でオープンに、質の高い解説を積み上げていきます。
            </p>
          </div>
          <div class="mt-10">
            <Button href="/about" variant="secondary" size="large" ariaLabel="詳しい説明へ">
              詳しく見る
            </Button>
          </div>
        </div>
      </div>
    </section>

    <!-- カテゴリ（テキスト中心・大きなアイコン円なし） -->
    <section id="categories" class="border-t border-mun-border py-16 md:py-20">
      <div class="container mx-auto px-6">
        <div class="mb-12 max-w-3xl">
          <h2 class="section-heading text-2xl md:text-3xl">記事の分かれ方</h2>
          <p class="section-lead">一覧では、次の観点で分類し、学びの導線をはっきり示しています（詳しくは <a href="/about" class="text-mun-link border-b border-mun-link/30 hover:border-mun-accent">このサイトについて</a>）。</p>
        </div>

        <Grid cols={4} gap="large">
          <Card ariaLabel="最新動向">
            <Stack gap="small" align="stretch">
              <h3 class="font-semibold text-lg font-noto text-mun-text">最新動向</h3>
              <p class="text-sm text-mun-text-muted leading-relaxed">
                判例・外交・条約の運用など、タイムリーな論点
              </p>
            </Stack>
          </Card>
          <Card ariaLabel="頻出トピック">
            <Stack gap="small" align="stretch">
              <h3 class="font-semibold text-lg font-noto text-mun-text">頻出トピック</h3>
              <p class="text-sm text-mun-text-muted leading-relaxed">
                会議で繰り返し扱われるテーマの整理
              </p>
            </Stack>
          </Card>
          <Card ariaLabel="コア文書">
            <Stack gap="small" align="stretch">
              <h3 class="font-semibold text-lg font-noto text-mun-text">コア文書</h3>
              <p class="text-sm text-mun-text-muted leading-relaxed">
                国連憲章など、議論の前提となる文書
              </p>
            </Stack>
          </Card>
          <Card ariaLabel="学問的探究">
            <Stack gap="small" align="stretch">
              <h3 class="font-semibold text-lg font-noto text-mun-text">学問的探究</h3>
              <p class="text-sm text-mun-text-muted leading-relaxed">
                理論・概念を丁寧に扱う、長めの記事
              </p>
            </Stack>
          </Card>
        </Grid>

        <p class="mt-12 text-center">
          <a href="/articles" class="text-sm font-medium text-mun-link hover:text-mun-accent border-b border-mun-link/30 hover:border-mun-accent transition-colors">
            すべての記事を見る
          </a>
        </p>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .line-clamp-4 {
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
