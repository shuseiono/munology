---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "送信完了 | MUNOLOGY";
---

<BaseLayout pageTitle={pageTitle}>
  <div class="page-main pt-16">
    <header class="page-hero">
      <div class="page-hero-inner">
        <h1 class="page-display-title">送信しました</h1>
        <p class="page-lead">
          お問い合わせありがとうございます。内容を確認のうえ、必要に応じてご返信します。
        </p>
        <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
          <a
            href="/"
            class="inline-block bg-mun-accent text-mun-bg font-semibold py-3 px-6 rounded-lg hover:opacity-90 transition-opacity text-center"
          >
            トップへ戻る
          </a>
          <a href="/contact" class="text-sm text-mun-link hover:text-mun-accent font-noto">
            別のお問い合わせを送る
          </a>
        </div>
      </div>
    </header>
  </div>
</BaseLayout>
