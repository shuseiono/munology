---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "About | MUNOLOGYについて";
---

<BaseLayout pageTitle={pageTitle}>
  <div class="page-main pt-16">
    <header class="page-hero">
      <div class="page-hero-inner">
        <h1 class="page-display-title">MUNOLOGYについて</h1>
        <p class="page-lead">
          模擬国連の体験を、法学・政治学の観点から読み解き、学びに接続することを目指しています。
        </p>
      </div>
    </header>

    <section class="py-14 md:py-20">
      <div class="container mx-auto px-6">
        <div class="max-w-3xl mx-auto">
          <h2 class="section-heading mb-6">ミッション</h2>
          <div class="space-y-5 text-mun-text-secondary leading-relaxed font-noto">
            <p>
              MUNOLOGYは、模擬国連という実践のあとに続く学びの場として、高校生以上の読者が国際法・国際政治を深く理解する手助けをしたいと考えています。
            </p>
            <p class="text-mun-text-muted">
              教育資源へのアクセスに差がある現実を踏まえ、質の高い解説テキストをオープンに届けることを重視します。
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-mun-border py-14 md:py-20">
      <div class="container mx-auto px-6">
        <div class="max-w-5xl mx-auto">
          <h2 class="section-heading mb-10 max-w-3xl">大切にしていること</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12">
            <div>
              <h3 class="font-semibold text-mun-text font-noto mb-3">学問的探究</h3>
              <p class="text-sm text-mun-text-muted leading-relaxed font-noto">
                法学・政治学の枠組みを明示し、根拠と論点が追える文章を心がけます。
              </p>
            </div>
            <div>
              <h3 class="font-semibold text-mun-text font-noto mb-3">アクセスの公平性</h3>
              <p class="text-sm text-mun-text-muted leading-relaxed font-noto">
                大学の講義に行けない読者にも、同等の議論に踏み込める材料を提供します。
              </p>
            </div>
            <div>
              <h3 class="font-semibold text-mun-text font-noto mb-3">次の世代</h3>
              <p class="text-sm text-mun-text-muted leading-relaxed font-noto">
                国際社会で責任を持って働く人材の育成に、コンテンツの面から貢献したいと考えています。
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-mun-border py-14 md:py-20">
      <div class="container mx-auto px-6">
        <div class="max-w-5xl mx-auto">
          <h2 class="section-heading mb-10">コンテンツの種類</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-sm font-noto">
            <li class="border border-mun-border rounded-lg p-5 bg-mun-surface/40">
              <span class="font-semibold text-mun-text block mb-2">最新動向</span>
              <span class="text-mun-text-muted">判例・外交・条約の運用など、タイムリーな論点</span>
            </li>
            <li class="border border-mun-border rounded-lg p-5 bg-mun-surface/40">
              <span class="font-semibold text-mun-text block mb-2">頻出トピック</span>
              <span class="text-mun-text-muted">会議で繰り返し登場するテーマの整理</span>
            </li>
            <li class="border border-mun-border rounded-lg p-5 bg-mun-surface/40">
              <span class="font-semibold text-mun-text block mb-2">コア文書</span>
              <span class="text-mun-text-muted">国連憲章など、議論の前提となる文書</span>
            </li>
            <li class="border border-mun-border rounded-lg p-5 bg-mun-surface/40">
              <span class="font-semibold text-mun-text block mb-2">学問的探究</span>
              <span class="text-mun-text-muted">理論・概念を丁寧に扱う長めの記事</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <section class="border-t border-mun-border py-14 md:py-20">
      <div class="container mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="section-heading mb-4">お問い合わせ</h2>
          <p class="text-mun-text-secondary font-noto leading-relaxed mb-8">
            ご質問やご意見は、フォームからお送りください。
          </p>
          <a
            href="/contact"
            class="inline-block bg-mun-accent text-mun-bg font-semibold py-3 px-8 rounded-lg hover:opacity-90 transition-opacity"
          >
            連絡フォームへ
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
