---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "ページが見つかりません | MUNOLOGY";
const launchDate = new Date('2025-11-17');
const currentDate = new Date();
const isLaunched = currentDate >= launchDate;
---

{isLaunched ? (
  <BaseLayout
    pageTitle={pageTitle}
    pageDescription="指定のURLにページが見つかりません。MUNOLOGY（Beyond the Gavel）。"
  >
    <div class="page-main pt-16">
      <header class="page-hero">
        <div class="page-hero-inner">
          <p class="text-sm text-mun-text-muted font-noto mb-3">404</p>
          <h1 class="page-display-title">ページが見つかりません</h1>
          <p class="page-lead">
            お探しのページは移動したか、削除された可能性があります。URLをご確認ください。
          </p>
          <div class="mt-10">
            <a
              href="/"
              class="inline-block bg-mun-accent text-mun-bg font-semibold py-3 px-6 rounded-lg hover:opacity-90 transition-opacity"
            >
              トップへ戻る
            </a>
          </div>
        </div>
      </header>
    </div>
  </BaseLayout>
) : (
  <BaseLayout pageTitle="近日公開 | MUNOLOGY" pageDescription="MUNOLOGY（Beyond the Gavel）の公開に向けた準備中のページです。">
    <div class="page-main pt-16">
      <header class="page-hero">
        <div class="page-hero-inner max-w-2xl">
          <h1 class="page-display-title">Coming Soon</h1>
          <p class="page-lead">
            模擬国連の体験を学問的な探究へと繋げる <strong class="font-semibold text-mun-text">MUNOLOGY</strong> を準備しています。
          </p>
          <p class="mt-6 text-sm text-mun-text-muted font-noto">
            公開予定: 2025年11月17日
          </p>
          <div class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-4 max-w-md text-sm font-noto text-mun-text-secondary">
            <div class="border border-mun-border rounded-md px-3 py-2 bg-mun-surface/40">
              <span class="block text-lg font-medium text-mun-text tabular-nums" id="days">--</span>
              日
            </div>
            <div class="border border-mun-border rounded-md px-3 py-2 bg-mun-surface/40">
              <span class="block text-lg font-medium text-mun-text tabular-nums" id="hours">--</span>
              時間
            </div>
            <div class="border border-mun-border rounded-md px-3 py-2 bg-mun-surface/40">
              <span class="block text-lg font-medium text-mun-text tabular-nums" id="minutes">--</span>
              分
            </div>
            <div class="border border-mun-border rounded-md px-3 py-2 bg-mun-surface/40">
              <span class="block text-lg font-medium text-mun-text tabular-nums" id="seconds">--</span>
              秒
            </div>
          </div>
          <p class="mt-10 text-sm text-mun-text-muted font-noto leading-relaxed max-w-xl">
            情報へのアクセスの偏りを少しでも減らすため、読み物を丁寧に用意していきます。
          </p>
        </div>
      </header>
    </div>

    <script>
      function updateCountdown() {
        const launch = new Date('2025-11-17T00:00:00').getTime();
        const now = new Date().getTime();
        const distance = launch - now;

        if (distance > 0) {
          const days = Math.floor(distance / (1000 * 60 * 60 * 24));
          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);

          const d = document.getElementById('days');
          const h = document.getElementById('hours');
          const m = document.getElementById('minutes');
          const s = document.getElementById('seconds');
          if (d) d.textContent = String(days);
          if (h) h.textContent = String(hours);
          if (m) m.textContent = String(minutes);
          if (s) s.textContent = String(seconds);
        } else {
          window.location.reload();
        }
      }
      updateCountdown();
      setInterval(updateCountdown, 1000);
    </script>
  </BaseLayout>
)}
