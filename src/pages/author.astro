---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Author | 執筆者";
---

<BaseLayout pageTitle={pageTitle}>
  <div class="page-main pt-16">
    <header class="page-hero">
      <div class="page-hero-inner">
        <h1 class="page-display-title">執筆者</h1>
        <p class="page-lead">MUNOLOGYの記事を書いている人たちについて、順次掲載していく予定です。</p>
      </div>
    </header>

    <section class="py-14 md:py-20">
      <div class="container mx-auto px-6">
        <div class="max-w-3xl mx-auto border border-mun-border rounded-lg p-8 md:p-10 bg-mun-surface/30">
          <p class="text-mun-text-secondary font-noto leading-relaxed mb-4">
            執筆者プロフィールは準備中です。
          </p>
          <p class="text-mun-text-muted text-sm font-noto leading-relaxed">
            公開までしばらくお待ちください。
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
