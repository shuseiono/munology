---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "執筆者 | MUNOLOGY";
const pageDescription = "MUNOLOGYの記事を担う執筆者の紹介。順次、プロフィールを掲げる予定です。";
---

<BaseLayout pageTitle={pageTitle} pageDescription={pageDescription}>
  <div class="page-main pt-16">
    <header class="page-hero">
      <div class="page-hero-inner">
        <h1 class="page-display-title">執筆者</h1>
        <p class="page-lead">
          学問的探究とアクセスの公平性を大切にし、<strong class="text-mun-text font-semibold">根拠と論点が追える</strong>文章を心がけている執筆者を、順次紹介していく予定です。
        </p>
      </div>
    </header>

    <section class="py-14 md:py-20">
      <div class="layout-shell">
        <div class="layout-narrow border border-mun-border rounded-lg p-6 sm:p-8 md:p-10 bg-mun-surface/30">
          <p class="text-mun-text-secondary font-noto leading-relaxed mb-4">
            執筆者プロフィールは準備中です。
          </p>
          <p class="text-mun-text-muted text-sm font-noto leading-relaxed">
            公開までしばらくお待ちください。
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
