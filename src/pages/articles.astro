---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) => !data.draft);
articles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const articlesByCategory: Record<string, typeof articles> = {};
articles.forEach((article) => {
  const category = article.data.category;
  if (!articlesByCategory[category]) {
    articlesByCategory[category] = [];
  }
  articlesByCategory[category].push(article);
});

const pageTitle = "記事一覧 | MUNOLOGY";
const pageDescription = "国際法・国際政治の記事をカテゴリ別に。最新動向・頻出トピック・コア文書・学問的探究。Beyond the Gavel。";
---

<BaseLayout pageTitle={pageTitle} pageDescription={pageDescription}>
  <div class="page-main pt-16">
    <header class="page-hero">
      <div class="page-hero-inner">
        <h1 class="page-display-title">記事一覧</h1>
        <p class="page-lead">
          会議用の要約の先、条文・判例・動向を扱う読み物を、<strong class="text-mun-text font-semibold">根拠と論点が追える</strong>形でカテゴリ別に掲げています。学術的・エディトリアルな厳しさを保ちつつ、web で到達しやすい導線に整えています。
        </p>
      </div>
    </header>

    <section class="py-12 md:py-16 lg:py-20">
      <div class="layout-shell">
        <div class="w-full max-w-6xl mx-auto">
          {articles.length > 0 ? (
            <div class="space-y-16 md:space-y-20">
              {Object.entries(articlesByCategory).map(([category, categoryArticles]) => (
                <div>
                  <header class="mb-8 pb-4 border-b border-mun-border max-w-3xl">
                    <h2 class="text-xl md:text-2xl font-semibold text-mun-text font-noto">{category}</h2>
                  </header>

                  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {categoryArticles.map((article) => (
                      <ArticleCard
                        title={article.data.title}
                        description={article.data.description}
                        category={article.data.category}
                        date={article.data.date}
                        tags={article.data.tags}
                        slug={article.slug}
                        image={article.data.image}
                      />
                    ))}
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="py-16 text-center">
              <p class="text-mun-text-secondary text-lg font-noto">記事がまだありません。</p>
              <p class="text-mun-text-muted text-sm mt-3 font-mono">件数: {articles.length}</p>
            </div>
          )}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
