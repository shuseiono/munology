---
// src/layouts/BaseLayout.astro
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  pageTitle: string;
  pageDescription?: string;
  pageImage?: string;
}

const { pageTitle, pageDescription, pageImage } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle} | MUNOLOGY</title>
    <meta name="description" content={pageDescription} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=Noto+Sans+JP:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
    <!-- Google Tag Manager（計測の正。GA4 等は GTM 内で配信すること — docs/PREMISES.md 参照） -->
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({
          "gtm.start": new Date().getTime(),
          event: "gtm.js",
        });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-TLDDNS2X");
    </script>
    
    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    {pageImage && <meta property="og:image" content={pageImage} />}
  </head>
  <body class="bg-mun-bg text-mun-text font-sans antialiased min-h-screen flex flex-col">
    <a
      href="#main-content"
      class="skip-link"
    >
      メインコンテンツにスキップ
    </a>

    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-TLDDNS2X"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >

    <Header />
    <main id="main-content" class="flex-1 w-full">
      <slot />
    </main>
    <Footer />
  </body>
</html>
